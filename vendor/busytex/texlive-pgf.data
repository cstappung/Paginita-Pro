    \pgfmathfpparse{#1}%
    \pgfmathfpmin@@{\pgfmathresult}{\pgfmath@result}%
}%
\def\pgfmathfpmin@#1{%
    \pgfmathfpmin@@#1%
}%
\def\pgfmathfpmin@@#1#2{%
    \begingroup%
        \FPiflt{#1}{#2}%
            \def\pgfmathresult{#1}%
        \else%
            \def\pgfmathresult{#2}%
        \fi%
        \pgfmath@smuggleone\pgfmathresult%
    \endgroup%
}%

