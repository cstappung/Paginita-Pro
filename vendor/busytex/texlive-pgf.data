      \advance\pgf@x\invertedradius%
    }{+\invertedradius}%
  }%
  \foregroundpath{\pgf@lib@sh@logicgates@IEC@foregroundpath{nand}}%
  \inheritanchorborder[from=and gate IEC]%
}%





