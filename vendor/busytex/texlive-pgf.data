%
\def\pgfmathfptan#1{%
    \pgfmathfpparse{#1}%
    \pgfmathfptan@{\pgfmathresult}%
}%
\def\pgfmathfptan@#1{%
    \begingroup%
        \FPmul\pgfmathresult{#1}{0.017453292519943295}%
