%
\def\pgfmathfpasin#1{%
    \pgfmathfpparse{#1}%
    \pgfmathfpasin@{\pgfmathresult}%
}%
\def\pgfmathfpasin@#1{%
    \begingroup%
        \FParcsin\pgfmathresult{#1}%
        \FPmul\pgfmathresult{\pgfmathresult}{57.295779513082320885}%
        \pgfmath@smuggleone\pgfmathresult%
