  \pgfpathmoveto{\pgfqpoint{0pt}{0pt}}%
  \pgfpathlineto{\pgfqpoint{3.1pt}{0pt}}%
  \pgfusepath{stroke}%
}%

\pgfdeclarepatternformonly{crosshatch}{\pgfqpoint{-1pt}{-1pt}}{\pgfqpoint{4pt}{4pt}}{\pgfqpoint{3pt}{3pt}}%
{%
