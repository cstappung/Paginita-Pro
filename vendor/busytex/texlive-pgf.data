          \expandafter\pgfparserdef@argstring@def\the\pgfparserdef@arg@count
          \pgfutil@namedef{\pgfparser@name{#1} #2 #3 code\expandafter}%
            \pgfparserdef@argstring##1##2##3##4##5##6##7##8##9%
            {#5\pgfparser@getnexttoken}%
