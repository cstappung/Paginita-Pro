\def\pgfutil@font@bfseries    {\bf}
\def\pgfutil@font@normalfont  {\tf}
\def\pgfutil@selectfont       {\tf}

% registers

\newcount\pgfutil@tempcnta
\newcount\pgfutil@tempcntb

