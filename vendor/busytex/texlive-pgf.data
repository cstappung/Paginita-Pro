\tikzset{at start/.style=                {pos=0}}%
\tikzset{very near start/.style=         {pos=0.125}}%
\tikzset{near start/.style=              {pos=0.25}}%
\tikzset{midway/.style=                  {pos=0.5}}%
\tikzset{near end/.style=                {pos=0.75}}%
\tikzset{very near end/.style=           {pos=0.875}}%
